{
  "manifest_version": 3,
  "name": "ChatGPT Speed Trim",
  "version": "0.1.0",
  "description": "Keep only the latest messages rendered in long ChatGPT chats to reduce lag.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "action": {
    "default_title": "ChatGPT Speed Trim",
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/injected/interceptor.js"
      ],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/shared/constants.js",
        "src/shared/storage.js",
        "src/content/bootstrap.js",
        "src/content/dom.js",
        "src/content/ui.js",
        "src/content/prune.js",
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_start"
    }
  ]
}
